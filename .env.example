# Public gateway/listener.
# The Go gateway intentionally uses the historical UVICORN_* names.
UVICORN_HOST = "0.0.0.0"
UVICORN_PORT = 8000
# REBECCA_GATEWAY_ADDR = ":8000"

# Gateway TLS.
# UVICORN_SSL_CERTFILE = "/var/lib/rebecca/certs/example.com/fullchain.pem"
# UVICORN_SSL_KEYFILE = "/var/lib/rebecca/certs/example.com/key.pem"
# UVICORN_SSL_CA_TYPE = "public"

# Dashboard serving.
# DASHBOARD_PATH = "/dashboard/"

# Binary phpMyAdmin helper.
# PHPMYADMIN_ENABLED = "false"
# PHPMYADMIN_PORT = "8080"
# PHPMYADMIN_PATH = "/phpmyadmin/"

# Database.
# SQLALCHEMY_DATABASE_URL = "sqlite:///db.sqlite3"

# Binary/install metadata.
# REBECCA_INSTALL_MODE = "binary"
# REBECCA_SCRIPT_BIN = "/usr/local/bin/rebecca"
# REBECCA_APP_DIR = "/opt/rebecca"
# REBECCA_DATA_DIR = "/var/lib/rebecca"
# REBECCA_SERVICE_NAME = "rebecca"

# Initial admin bootstrap.
# SUDO_USERNAME = "admin"
# SUDO_PASSWORD = "admin"

# Node operations and user lifecycle jobs.
# REBECCA_NODE_OPERATIONS_POLL_INTERVAL = "15s"
# REBECCA_NODE_USAGE_COLLECTION_INTERVAL = "30s"
# REBECCA_NODE_USAGE_COLLECTION_LIMIT = 0
# REBECCA_USER_LIFECYCLE_INTERVAL = "10s"
# REBECCA_USER_LIFECYCLE_BATCH_SIZE = 500
# REBECCA_USER_USAGE_RESET_INTERVAL = "1h"
# REBECCA_USER_USAGE_RESET_BATCH_SIZE = 500
# REBECCA_USER_AUTODELETE_INTERVAL = "1h"
# REBECCA_USER_AUTODELETE_BATCH_SIZE = 500
# USERS_AUTODELETE_DAYS = -1
# USER_AUTODELETE_INCLUDE_LIMITED_ACCOUNTS = false

# API behavior.
# JWT_ACCESS_TOKEN_EXPIRE_MINUTES = 1440
# USERS_LIST_TIMEOUT_SECONDS = 0
# SUBSCRIPTION_READ_ONLY = false

# CLI subscription helpers.
# XRAY_SUBSCRIPTION_URL_PREFIX = "https://example.com"

# Xray config builder.
# XRAY_EXCLUDE_INBOUND_TAGS = "INBOUND_X INBOUND_Y"
# XRAY_FALLBACKS_INBOUND_TAG = "INBOUND_X"
# GEO_TEMPLATES_INDEX_URL = "https://raw.githubusercontent.com/example/geo-templates/main/index.json"

# Settings, templates, certificates, and backup roots.
# REBECCA_APP_TEMPLATE_BASE = "/opt/rebecca/templates"
# REBECCA_CERT_BASE = "/var/lib/rebecca/certs"
# REBECCA_CONFIG_DIR = "/etc/rebecca"

# WARP.
# REBECCA_WARP_API_BASE = "https://api.cloudflareclient.com/v0a2158"
